{
  "name": "focus-tower",
  "version": "1.1.0",
  "description": "Chrome extension — block distracting websites with inspiring messages",
  "type": "module",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "watch": "bun --watch scripts/build.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test src",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "package": "bun run build && cd dist && zip -r ../focus-tower.zip .",
    "icons": "bun run scripts/generate-icons.ts",
    "pixel-tower": "bun run scripts/generate-pixel-tower.ts",
    "watcher-eye": "bun run scripts/generate-watcher-eye.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/grinn/focus-tower.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.2.0",
    "@types/chrome": "^0.0.268",
    "typescript": "^5.7.3"
  }
}
