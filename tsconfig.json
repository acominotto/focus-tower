{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["chrome", "bun"]
  },
  "include": ["src/**/*", "scripts/**/*", "e2e/**/*", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
